# ===========================================
# REQUIRED - Must be set before deployment
# ===========================================

# S3 bucket for session data (auto-populated by main README deployment steps)
S3_BUCKET_NAME=geospatial-agent-on-aws-YOUR_ACCOUNT_ID

# IAM Role ARN (created by agentcore_utils/create_cdk_agent_role.py)
AGENTCORE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/agentcore-geospatial-agent-on-aws-role

# ===========================================
# OPTIONAL - Defaults work for most cases
# ===========================================

AWS_REGION=us-east-1
MODEL_ID=us.anthropic.claude-sonnet-4-6

# ===========================================
# LANGFUSE - Only needed for deploy_with_langfuse.sh
# ===========================================

# LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
# LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_PROJECT_NAME=your-project-name
