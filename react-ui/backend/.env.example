# AWS Configuration
AWS_REGION=us-east-1
# Note: For local development, configure AWS credentials via AWS CLI or environment variables
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# AgentCore Configuration (Required)
# Get this ARN from your deployed geo_agent (.bedrock_agentcore.yaml)
AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:YOUR_ACCOUNT_ID:runtime/YOUR_AGENT_ID

# S3 Configuration (Required)
S3_BUCKET_NAME=geospatial-agent-on-aws-YOUR_ACCOUNT_ID

# Server Configuration
PORT=3001
FRONTEND_URL=http://localhost:5173
